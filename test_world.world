<?xml version="1.0" ?>
<sdf version="1.8">
  <world name="photorealistic_office">
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <light type="point" name="office_lamp_1"><pose>3 0 2.5 0 0 0</pose><diffuse>0.9 0.8 0.7 1</diffuse><attenuation><range>15</range><constant>0.5</constant></attenuation><cast_shadows>true</cast_shadows></light>
    <light type="point" name="office_lamp_2"><pose>8 0 2.5 0 0 0</pose><diffuse>0.9 0.8 0.7 1</diffuse><attenuation><range>15</range><constant>0.5</constant></attenuation><cast_shadows>true</cast_shadows></light>

    <model name="office_floor">
      <static>true</static>
      <link name="link">
        <collision name="c"><geometry><plane><normal>0 0 1</normal><size>50 50</size></plane></geometry></collision>
        <visual name="v">
          <geometry><plane><normal>0 0 1</normal><size>50 50</size></plane></geometry>
          <material><ambient>0.4 0.25 0.1 1</ambient><diffuse>0.5 0.3 0.15 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="launch_tube">
      <static>true</static>
      <pose>0 0 0.5 0 1.5708 0</pose> 
      <link name="link">
        <visual name="v"><geometry><cylinder><radius>0.4</radius><length>2.5</length></cylinder></geometry><material><ambient>0.1 0.1 0.1 1</ambient></material></visual>
        <collision name="c"><geometry><cylinder><radius>0.4</radius><length>2.5</length></cylinder></geometry></collision>
      </link>
    </model>

    <model name="office_complex">
      <static>true</static>
      <pose>7 0 0 0 0 0</pose>
      <link name="wall_l"><pose>0 3 1.5 0 0 0</pose><visual name="v"><geometry><box><size>14 0.1 3</size></box></geometry><material><ambient>0.9 0.9 0.9 1</ambient></material></visual></link>
      <link name="wall_r"><pose>0 -3 1.5 0 0 0</pose><visual name="v"><geometry><box><size>14 0.1 3</size></box></geometry><material><ambient>0.9 0.9 0.9 1</ambient></material></visual></link>
      
      <link name="room1_wall"><pose>-2 1.5 1.5 0 0 1.57</pose>
        <visual name="v"><geometry><box><size>3 0.1 3</size></box></geometry><material><ambient>0.8 0.8 0.8 1</ambient></material></visual>
      </link>
      
      <link name="room2_wall"><pose>2 -1.5 1.5 0 0 1.57</pose>
        <visual name="v"><geometry><box><size>3 0.1 3</size></box></geometry><material><ambient>0.8 0.8 0.8 1</ambient></material></visual>
      </link>

      <link name="table_top"><pose>-2 2.2 0.75 0 0 0</pose>
        <visual name="v"><geometry><box><size>1.2 0.8 0.05</size></box></geometry><material><ambient>0.3 0.2 0.1 1</ambient></material></visual>
      </link>

      <link name="ceiling"><pose>0 0 3 0 0 0</pose>
        <visual name="v"><geometry><box><size>14 6 0.1</size></box></geometry><material><ambient>0.6 0.6 0.6 0.2</ambient></material></visual>
      </link>
    </model>

    <include>
      <name>beam_chair_1</name>
      <uri>model://beam_chair</uri>
      <pose>6.0 0.5 0 0 0 0</pose>
    </include>

    <model name="drone">
      <pose>-0.5 0 0.5 0 0 0</pose> 
      <link name="base_link">
        <visual name="visual">
          <geometry><box><size>0.3 0.3 0.1</size></box></geometry>
          <material><ambient>0 1 0 1</ambient></material>
        </visual>
        <sensor name="camera" type="camera">
          <pose>0.15 0 0 0 0 0</pose>
          <always_on>1</always_on>
          <update_rate>30</update_rate>
          <visualize>true</visualize>
          <topic>camera</topic>
        </sensor>
      </link>
      <plugin filename="gz-sim-velocity-control-system" name="gz::sim::systems::VelocityControl"><link_name>base_link</link_name></plugin>
    </model>
  </world>
</sdf>